{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://dev318299.service-now.com/api/:path*"
    },
    {
      "source": "/oauth_token.do",
      "destination": "https://dev318299.service-now.com/oauth_token.do"
    },
    {
      "source": "/home",
      "destination": "/index.html"
    },
    {
      "source": "/profile",
      "destination": "/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
