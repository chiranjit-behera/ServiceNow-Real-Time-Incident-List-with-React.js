{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "routes": [
    { "handle": "filesystem" },
    {
      "src": "/api/(.*)",
      "dest": "https://dev318299.service-now.com/api/$1"
    },
    {
      "src": "/oauth_token\\.do",
      "dest": "https://dev318299.service-now.com/oauth_token.do"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
